/* eslint-disable no-undef */ 'use strict';
var photos = document.querySelectorAll('.photos__photo');
var dots = document.querySelectorAll('.gallery__dot');
var slider = document.querySelector('.photos');
var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
        if (entry.isIntersecting) {
            var index = Array.from(photos).indexOf(entry.target);
            dots.forEach(function(dot) {
                return dot.classList.remove('gallery__dot--active');
            });
            dots[index].classList.add('gallery__dot--active');
        }
    });
}, {
    root: slider,
    rootMargin: '0px -50% 0px 0px',
    threshold: 0
});
photos.forEach(function(photo) {
    return observer.observe(photo);
});
dots.forEach(function(dot, index) {
    dot.addEventListener('click', function(e) {
        e.preventDefault();
        photos[index].scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'start'
        });
    });
});

